{
  "schema_version": "2.0.0",
  "description": "Doctor OS manifest v2 — declarative probe/chaos/heal/intelligence configuration",

  "probes": {
    "startup": {
      "commands": ["npm run -s ops:baseline:restore", "npm run -s verify:fast"],
      "timeout_ms": 120000,
      "failure_action": "ABORT",
      "weight": 10
    },
    "liveness": {
      "commands": ["npm run -s verify:fast", "npm run -s verify:fast", "npm run -s ops:life"],
      "timeout_ms": 300000,
      "failure_action": "REPORT",
      "x2_determinism": true,
      "weight": 30
    },
    "readiness": {
      "commands": ["npm run -s verify:doctor:policy"],
      "timeout_ms": 180000,
      "failure_action": "REPORT",
      "weight": 24
    }
  },

  "chaos": {
    "chaos_mode_lie": {
      "description": "Inject mode:CERT into RESEARCH_NET temp file, verify SAN catches it",
      "gate_id": "CHAOS_MODE_LIE",
      "scanner": "san_research_net_logic",
      "injection": { "pattern": "mode: 'CERT'", "zone": "RESEARCH_NET" },
      "expected": "CAUGHT"
    },
    "chaos_orphan": {
      "description": "Inject orphan dir into temp evidence root, verify SANM01 catches it",
      "gate_id": "CHAOS_ORPHAN",
      "scanner": "san_mutation_logic",
      "injection": { "dir_name": "_CHAOS_TEST_ORPHAN_" },
      "expected": "CAUGHT"
    },
    "chaos_fp01_trap": {
      "description": "Write JSON with forbidden field, verify FP01 throws",
      "gate_id": "CHAOS_FP01",
      "scanner": "writeJsonDeterministic",
      "injection": { "field": "created_at", "value": "2026-01-01T00:00:00Z" },
      "expected": "FP01_THROWN"
    },
    "chaos_evidence_tamper": {
      "description": "Tamper with merkle-sealed evidence, verify provenance detects it",
      "gate_id": "CHAOS_EVIDENCE_TAMPER",
      "scanner": "verifyProvenance",
      "injection": { "action": "modify_sealed_file" },
      "expected": "TAMPER_DETECTED"
    },
    "chaos_net_leak": {
      "description": "Attempt network I/O under TREASURE_NET_KILL=1, verify NETV01 thrown",
      "gate_id": "CHAOS_NET_LEAK",
      "scanner": "net_kill_preload",
      "injection": { "action": "http_get_attempt" },
      "expected": "NETV01_THROWN"
    }
  },

  "taxonomy": {
    "CHAOS_MODE_LIE":        { "scoreboard_key": "chaos_mode_lie",        "script": "scripts/verify/chaos_mode_lie.mjs" },
    "CHAOS_ORPHAN":          { "scoreboard_key": "chaos_orphan",          "script": "scripts/verify/chaos_orphan_write.mjs" },
    "CHAOS_FP01":            { "scoreboard_key": "chaos_fp01",            "script": "scripts/verify/chaos_fp01_trap.mjs" },
    "CHAOS_EVIDENCE_TAMPER": { "scoreboard_key": "chaos_evidence_tamper", "script": "scripts/verify/chaos_evidence_tamper.mjs" },
    "CHAOS_NET_LEAK":        { "scoreboard_key": "chaos_net_leak",        "script": "scripts/verify/chaos_net_leak.mjs" }
  },

  "self_heal": {
    "stale_baseline":     { "detect": "baseline_restore_needed", "fix": "npm run -s ops:baseline:restore", "scope": "INFRASTRUCTURE" },
    "orphan_in_evidence": { "detect": "orphan_scan", "fix": "quarantine_to_artifacts", "scope": "INFRASTRUCTURE" },
    "executor_missing":   { "detect": "executor_dir_check", "fix": "mkdir_recursive", "scope": "INFRASTRUCTURE" },
    "git_missing":        { "detect": "git_dir_check", "fix": "git_init_commit", "scope": "INFRASTRUCTURE" },
    "node_modules_gone":  { "detect": "node_modules_check", "fix": "npm_ci", "scope": "INFRASTRUCTURE" }
  },

  "scoreboard_v2": {
    "startup_boot": 10,
    "liveness_alive": 15,
    "liveness_deterministic": 15,
    "readiness_policy": 16,
    "readiness_san": 8,
    "chaos_mode_lie": 7,
    "chaos_orphan": 7,
    "chaos_fp01": 4,
    "chaos_evidence_tamper": 6,
    "chaos_net_leak": 4,
    "provenance_sealed": 3,
    "differential_clean": 5
  },

  "trending": {
    "window_runs": 10,
    "pareto_k": 5,
    "decay_min_drop": 2,
    "improve_min_rise": 2,
    "imperfect_threshold": 100,
    "max_score_history": 200
  },

  "escalation": {
    "stage_1_drops": 2,
    "stage_2_drops": 3,
    "stage_3_drops": 5,
    "stage_3_min_score": 50,
    "big_drop_threshold": 15
  },

  "predictive": {
    "min_data_points": 5,
    "momentum_window": 3,
    "risk_thresholds": {
      "medium": 20,
      "high": 50
    }
  }
}
